# --- Ozon parsing ---
OZON_CATEGORY_URL=https://www.ozon.ru/category/smartfony-15502/
TARGET_PRODUCT_COUNT=10000
# Локальное демо: 100 товаров. Для полного прогона → false
DEMO_MODE=true
DEMO_TARGET_COUNT=100
REQUEST_DELAY_MS=800
# true = синтетический каталог (рекомендуется: composer-api часто отвечает 403 antibot)
PARSER_MOCK=true

# --- OpenAI ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
LLM_BATCH_SIZE=50
# true = rule-based сегменты без расходов на API (нет квоты → оставьте true)
LLM_MOCK=true

# --- AmoCRM ---
AMOCRM_SUBDOMAIN=your-subdomain
AMOCRM_ACCESS_TOKEN=
AMOCRM_REFRESH_TOKEN=
AMOCRM_CLIENT_ID=
AMOCRM_CLIENT_SECRET=
AMOCRM_REDIRECT_URI=https://example.com
# true = задачи в data/tasks.json; false = реальный POST /api/v4/tasks
CRM_MOCK=true
CRM_TASK_LIMIT=10

# --- Storage ---
DATA_DIR=data
CHECKPOINT_DIR=data/checkpoints
